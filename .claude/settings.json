{
	"env": {
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
	},
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/post-write.sh\"",
						"statusMessage": "Running post-write checks..."
					},
					{
						"type": "command",
						"command": "make -C \"${CLAUDE_PROJECT_DIR:-.}\" format",
						"statusMessage": "Formatting code (in container)...",
						"async": true
					},
					{
						"type": "command",
						"command": "make -C \"${CLAUDE_PROJECT_DIR:-.}\" typecheck",
						"statusMessage": "Type checking (in container)...",
						"async": true
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/post-bash.sh\"",
						"statusMessage": "Verifying HTML asset paths..."
					}
				]
			}
		]
	}
}
