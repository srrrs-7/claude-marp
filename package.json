{
	"name": "claude-marp",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"slides": "bun run src/index.ts",
		"single": "bun run scripts/single.ts",
		"validate": "bun run scripts/validate-slides-schema.ts",
		"validate:quality": "bun run scripts/validate-slides-schema.ts --quality",
		"fix": "bun run scripts/auto-fix-slides-schema.ts",
		"split": "bun run scripts/split-code-diagrams.ts --all",
		"split:bullets": "bun run scripts/split-bullet-overflow.ts",
		"fix-svg": "bun run scripts/fix-svg-overflow.ts",
		"rebuild": "bun run scripts/rebuild-all-slides.ts",
		"rebuild:render": "bun run scripts/rebuild-all-slides.ts render",
		"rebuild:export": "bun run scripts/rebuild-all-slides.ts export",
		"typecheck": "tsgo --noEmit",
		"check": "biome check .",
		"format": "biome format --write .",
		"spellcheck": "cspell lint --no-progress --show-suggestions .",
		"test": "bun test scripts/test-slides.test.ts src/__tests__/*.test.ts scripts/__tests__/*.test.ts",
		"generate:index": "bun run scripts/generate-index.ts",
		"fix:all": "bun run fix && bun run split && bun run scripts/split-bullet-overflow.ts --all && bun run fix-svg && bun scripts/fix-svg-url-refs.ts && bun run generate:index",
		"doctor": "bun run scripts/doctor.ts",
		"dev": "bun run scripts/dev-watch.ts",
		"stats": "bun run scripts/stats.ts",
		"lint": "bun run validate && bun run validate:quality",
		"team": "bash scripts/setup-agent-team.sh",
		"team:status": "bash scripts/agent-team-status.sh"
	},
	"dependencies": {
		"@marp-team/marp-cli": "^4.1.2",
		"yaml": "^2.7.0",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@bun-security-scanner/osv": "^1.0.0",
		"@types/bun": "^1.2.4",
		"@typescript/native-preview": "^7.0.0-dev.20260213.1",
		"cspell": "^9.6.4"
	}
}
